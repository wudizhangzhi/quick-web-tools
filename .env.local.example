# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
# 仅在生产环境（NODE_ENV=production）下生效，本地 dev 不会上报
NEXT_PUBLIC_GA_ID=

# Vercel Web Analytics — 默认关闭（Hobby 免费档只有 2.5k events/月）。
# 想启用就设 'true'，配合 Vercel 项目里 Analytics 已开通使用。
VERCEL_ANALYTICS_ENABLED=

# world-cup-predict
# 用假赛果填充所有比赛，方便本地调试"有结果"时的样式（正确率/称谓/✓✗/晋级高亮）。
# 默认 false（不设即视为 false），仅本地设 'true'。生产永远别开。
WC_MOCK_RESULTS=false

# force-yes
# Upstash Redis — choose ONE pair:
#   - From console.upstash.com (Direct):     UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
#   - From Vercel Marketplace (Upstash):     KV_REST_API_URL       / KV_REST_API_TOKEN
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Cloudflare Turnstile
# For local dev use Cloudflare's official test keys (always pass on any domain):
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
